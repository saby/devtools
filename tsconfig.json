{
  "extends": "./config/tsconfig",
  "compilerOptions": {
    "baseUrl": "./src",
    "strictBindCallApply": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "paths": {
      "Extension/*": [
        "./shared/Extension/*"
      ],
      "tslib": [
        "./extension/ext/tslib"
      ]
    }
  }
}
