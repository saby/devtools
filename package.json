{
   "name": "saby-devtool",
   "version": "0.1.0",
   "license": "MS-RL",
   "repository": {
      "type": "git",
      "url": "git@github.com:saby/devtools.git"
   },
   "scripts": {
      "build": "npm run build:shared && npm run build:extension && npm run build:injection && npm run build:app && npm run build:cdn",
      "build:injection": "node ./scripts/build_injection.js",
      "build:injection-min": "node ./scripts/build_injection.js -min",
      "build:content": "node ./scripts/build_content.js",
      "build:content-min": "node ./scripts/build_content.js -min",
      "build:extension": "node ./scripts/build_extension.js && npm run build:content",
      "build:app": "node ./scripts/build_app.js",
      "build:cdn": "node ./scripts/build_cdn.js",
      "build:shared": "node ./scripts/copy_shared.js"
   },
   "devDependencies": {
      "@types/chrome": "0.0.81",
      "tslint": "^5.15.0"
   },
   "dependencies": {
      "cdn": "git+https://github.com/saby/wasaby-cdn.git#rc-19.410",
      "gulp": "^4.0.0",
      "rollup": "^1.6.0",
      "rollup-plugin-terser": "^5.0.0",
      "rollup-plugin-typescript": "^1.0.0",
      "tslib": "^1.9.3",
      "typescript": "^3.4.3",
      "rmi": "git+https://git.sbis.ru/sbis/rmi.git#rc-19.410",
      "saby-i18n": "git+https://github.com/saby/i18n.git#rc-19.410",
      "saby-types": "git+https://github.com/saby/Types.git#rc-19.410",
      "saby-typescript": "git+https://github.com/saby/TypeScript.git#rc-19.410",
      "sbis3-builder": "git+https://github.com/saby/Builder.git#rc-19.410",
      "sbis3-controls": "git+http://git.sbis.ru/sbis/controls.git#rc-19.410",
      "saby-ui": "git+https://github.com/saby/UI.git#rc-19.410",
      "sbis3-ws": "git+https://git.sbis.ru/sbis/ws.git#rc-19.410",
      "wasaby-app": "git+https://github.com/saby/wasaby-app.git#rc-19.410",
      "sbis3.engine": "git+https://git.sbis.ru/sbis/engine.git#rc-19.410"
   }
}
