<Controls.grid:View
    keyProperty="id"
    name="listView"
    bind:sorting="_sorting"
    displayProperty="name"
    columns="{{ _options.columns }}"
    header="{{ _options.headers }}"
    navigation="{{ _options.navigation }}"
    virtualScrolling="{{ true }}"
    virtualPageSize="{{ 70 }}"
    scope="{{ _options }}"
>
    <ws:emptyTemplate>
        <ws:partial template="Controls/list:EmptyTemplate" topSpacing="xl" bottomSpacing="xxl">
            <ws:contentTemplate>{[Не найдено]}</ws:contentTemplate>
        </ws:partial>
    </ws:emptyTemplate>
</Controls.grid:View>
