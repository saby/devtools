<Controls.grid:View
    keyProperty="id"
    name="listView"
    bind:sorting="_sorting"
    displayProperty="name"
    columns="{{ _column }}"
    header="{{ _headers }}"
    navigation="{{ _navigation }}"
    scope="{{ _options }}"
>
    <ws:emptyTemplate>
        <ws:partial template="Controls/list:EmptyTemplate" topSpacing="xl" bottomSpacing="xxl">
            <ws:contentTemplate>{[Не найдено]}</ws:contentTemplate>
        </ws:partial>
    </ws:emptyTemplate>
</Controls.grid:View>
