<ws:if data="{{ itemData.item.isDynamic }}">
    <Controls.popup:InfoboxTarget attr:style="width: 100%;">
        <ws:content>
            <div class="icon-small icon-Info icon-disabled"></div>
        </ws:content>
        <ws:template>
            <p>
                <h1>{[Динамическая зависимость модуля]}</h1>
            </p>
        </ws:template>
    </Controls.popup:InfoboxTarget>
</ws:if>
