<ws:if data="{{ _options.itemData.item.fileName }}">
    <Controls.buttons:Button caption="{{ _options.itemData.item.fileName }}"
                             tooltip="{{ _options.itemData.item.path }}"
                             viewMode="link"
                             on:click="__openResource(_options.itemData.item)"/>
</ws:if>
<ws:else>
    <invisible-node />
</ws:else>
