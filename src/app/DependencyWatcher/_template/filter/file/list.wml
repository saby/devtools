<Controls.list:View
    displayProperty="name"
    keyProperty="id"
>
    <ws:navigation source="page" view="infinity">
        <ws:sourceConfig pageSize="{{ 50 }}" page="{{ 0 }}" mode="totalCount"></ws:sourceConfig>
    </ws:navigation>
    <ws:emptyTemplate>
        <ws:partial template="Controls/list:EmptyTemplate" topSpacing="xl" bottomSpacing="xxl">
            <ws:contentTemplate>{[Не найдено]}</ws:contentTemplate>
        </ws:partial>
    </ws:emptyTemplate>
</Controls.list:View>
