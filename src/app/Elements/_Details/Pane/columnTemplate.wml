<ws:partial template="Controls/grid:ColumnTemplate" scope="{{ _options }}">
   <ws:contentTemplate>
      <ws:partial template="{{ itemData.item.template }}"
                  caption="{{ itemData.item.caption }}"
                  name="{{ itemData.item.name }}"
                  key="{{ itemData.item.key }}"
                  itemData="{{ itemData }}"/>
   </ws:contentTemplate>
</ws:partial>
