<ws:partial template="Controls/grid:ColumnTemplate" scope="{{ _options }}">
   <ws:contentTemplate>
      <ws:partial template="{{ itemData.column.getTemplate(itemData.item.value) }}"
                  value="{{ itemData.item.value }}"
                  name="{{ itemData.item.name }}"
                  key="{{ itemData.item.key }}"
                  itemData="{{ itemData }}"/>
   </ws:contentTemplate>
</ws:partial>
