<span>
   <span attr:class="BooleanTemplate__fieldName">{{_options.name}}</span>:
   <ws:if data="{{ _options.itemData.isEditing }}">
      <Controls.toggle:Checkbox bind:value="_options.itemData.item.value" />
   </ws:if>
   <ws:else>
      <Controls.toggle:Checkbox value="{{_options.value}}"
                                readOnly="{{ true }}" />
   </ws:else>
   <span attr:class="BooleanTemplate__value"> {{_options.value}}</span>
</span>
