<div attr:style="display: flex;">
    <ws:if data="{{_options.elements}}">
        <ws:for data="element in _options.elements">
            <div attr:key="{{element.id}}"
                 on:click="_onItemClick(element)">{{element.name}}</div>
        </ws:for>
        <Elements.Details.Details scope="{{_selectedItem}}" />
    </ws:if>
    <ws:else>
        <div>Connecting to Wasaby...</div>
    </ws:else>
</div>