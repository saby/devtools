<ws:partial template="Controls/list:ItemTemplate"
            scope="{{ _options }}">
   <ws:contentTemplate>
      <Profiler._TimeRender.TimeRender value="{{ itemData.item.selfDuration }}"
                                      barColor="{{ itemData.item.barColor }}"
                                      length="{{ itemData.item.length }}"/>
   </ws:contentTemplate>
</ws:partial>
